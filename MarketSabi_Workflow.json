        576
      ],
      "id": "301f5605-a80f-4a54-905b-ff783056bfbd",
      "name": "Code in JavaScript2"
    },
    {
      "parameters": {
        "jsCode": "// Collect all items from the Wait node\nconst rows = $input.all();\n\n// Build a readable summary string\nconst summary = rows.map(r => {\n  const d = r.json;\n  return `${d.Item || 'N/A'} | Qty: ${d.Quantity || 0} | Price: ₦${d.Amount || 0}`;\n}).join('\\n');\n\n// Return as single item for AI Agent3\nreturn [{ json: { allRows: summary, rowCount: rows.length } }];"
      },
