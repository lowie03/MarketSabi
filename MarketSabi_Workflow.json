    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.output || $input.first().json.text || \"\";\n\n// Clean up markdown symbols Telegram can't handle\nconst cleaned = raw\n  .replace(/\\*\\*(.*?)\\*\\*/g, '*$1*')   // convert **bold** to *bold* (Telegram style)\n  .replace(/\\\\n/g, '\\n')                // fix literal \\n into real line breaks\n  .trim();\n\nreturn [{ json: { cleanMessage: cleaned } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
